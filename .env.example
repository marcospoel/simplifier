# Simplifier instance base URL (no trailing slash)
SIMPLIFIER_BASE_URL=https://tsystems-eval.simplifier.cloud

# Session token — obtain from Simplifier user profile → "Copy current token"
# Expires on logout. Must be refreshed and MCP restarted after each new login.
SIMPLIFIER_TOKEN=

# Alternative to SIMPLIFIER_TOKEN: path to a JSON credentials file
# File format: { "user": "youruser", "pass": "yourpassword" }
# Do NOT set both SIMPLIFIER_TOKEN and SIMPLIFIER_CREDENTIALS_FILE at the same time.
# SIMPLIFIER_CREDENTIALS_FILE=./.credentials

# Optional: log all HTTP requests from the MCP to a file for debugging
# HTTP_REQUEST_LOG_FILE=./mcp-http.log

# Figma personal access token (needed only if using Figma REST API directly)
# FIGMA_ACCESS_TOKEN=
